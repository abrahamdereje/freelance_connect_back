APP_NAME=FreelanceConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------------------
# DATABASE — MySQL (local)
# Run: php artisan db:create   (creates DB if missing)
# Run: php artisan migrate:fresh --seed
# -------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=freelanceconnect
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -------------------------------------------------------------------
# BROADCASTING — Laravel Reverb (WebSocket, local only)
# Run: php artisan reverb:start
# -------------------------------------------------------------------
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=freelanceconnect
REVERB_APP_KEY=freelanceconnect-key
REVERB_APP_SECRET=freelanceconnect-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -------------------------------------------------------------------
# QUEUES & CACHE
# -------------------------------------------------------------------
QUEUE_CONNECTION=sync
CACHE_STORE=array

FILESYSTEM_DISK=local

# -------------------------------------------------------------------
# MAIL (log driver — no real mail in local dev)
# -------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@freelanceconnect.local"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------------------
# SANCTUM — token-based auth
# -------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# -------------------------------------------------------------------
# VITE
# -------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
